-- echo vector schema boundaries

create table t_vec_default(id int, emb vector);
create table t_vec_empty(emb vector());
create table t_vec_too_big(emb vector(16384));

-- echo vector schema and insert

create table t_vec(id int, emb vector(3), tag char);
insert into t_vec values(1, string_to_vector('[1, 0, 0]'), 'a');
insert into t_vec values(2, string_to_vector('[3, 0, 0]'), 'b');
insert into t_vec values(3, string_to_vector('[6, 0, 0]'), 'c');
insert into t_vec values(4, string_to_vector('[-2, 0, 0]'), 'd');
insert into t_vec values(5, string_to_vector('[1, 2]'), 'bad');
insert into t_vec values(6, string_to_vector('[not-a-vector]'), 'bad');

-- echo vector conversion and comparison
select id, vector_to_string(emb) as emb_text from t_vec where emb = string_to_vector('[1,0,0]');
select id from t_vec where emb <> string_to_vector('[1,0,0]');
select id from t_vec where emb > string_to_vector('[0,0,0]');
select id from t_vec where emb = 'x';

-- echo distance functions
select vector_to_string(string_to_vector('[-1.5, 0, 2.25]')) as v from t_vec limit 1;
select distance(string_to_vector('[1,2]'), string_to_vector('[4,6]'), euclidean) as l2 from t_vec limit 1;
select distance(string_to_vector('[1,0]'), string_to_vector('[0,1]'), cosine) as cos from t_vec limit 1;
select distance(string_to_vector('[1,2,3]'), string_to_vector('[4,5,6]'), 'INNER_PRODUCT') as dot from t_vec limit 1;
select id from t_vec order by distance(emb, string_to_vector('[0,0]'), euclidean) asc limit 1;
select id from t_vec order by distance(emb, string_to_vector('[0,0,0]'), unknown_method) asc limit 1;

-- echo distance, alias order by and limit
select id, distance(emb, string_to_vector('[0,0,0]'), euclidean) as dis from t_vec order by dis asc limit 2;
select id, distance(emb, string_to_vector('[1,0,0]'), 'DOT') as score from t_vec order by score desc limit 2;
select id from t_vec order by distance(emb, string_to_vector('[0,0,0]'), euclidean) desc limit 1;

-- echo vector index defaults
create vector index idx_vec on t_vec(emb);
-- ensure:vector_index_scan select id, distance(emb, string_to_vector('[0,0,0]'), euclidean) as dis from t_vec order by distance(emb, string_to_vector('[0,0,0]'), euclidean) asc limit 2;
select id, distance(emb, string_to_vector('[0,0,0]'), euclidean) as dis from t_vec order by distance(emb, string_to_vector('[0,0,0]'), euclidean) asc limit 2;
create vector index idx_vec_bad_scalar on t_vec(tag);
create vector index idx_vec_bad_lists on t_vec(emb) with (lists=0);

-- echo vector index custom options
create table t_vec_custom(id int, emb vector(2));
insert into t_vec_custom values(1, string_to_vector('[1.5, -2]'));
insert into t_vec_custom values(2, string_to_vector('[0, 3]'));
create vector index idx_vec_custom on t_vec_custom(emb) with (distance=cosine, type=ivfflat, lists=2, probes=1);
-- ensure:vector_index_scan select id from t_vec_custom order by distance(emb, string_to_vector('[1,0]'), cosine) asc limit 1;
select id from t_vec_custom order by distance(emb, string_to_vector('[1,0]'), cosine) asc limit 1;
